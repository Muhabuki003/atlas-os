# Atlas OS — Environment Configuration

## Atlas CE workspace
ATLAS_WORKSPACE_PATH=./AtlasWorkspace
ATLAS_WORKSPACE_MODE=managed
ATLAS_WORKSPACE_CONTAINER=/workspace

## LLM providers — Ollama on Docker host
OPENAI_API_KEY=
OLLAMA_API_BASE=http://host.docker.internal:11434
ANTHROPIC_API_KEY=

## Web UI bind
APP_BIND=0.0.0.0
APP_PORT=7000
AUTH_ENABLED=true

## Search & vector store
SEARXNG_INSTANCE=http://localhost:8080

## Security
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://atlas.bookistudios.com
SECURE_COOKIES=true
